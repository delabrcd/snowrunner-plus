# Local machine config (install paths) — never commit; see .env.local.example
.env.local

# Build artifacts
build/
*.o
*.obj
*.dll
!docs/**/*.dll
*.pdb

# Frida / recon dumps
*.log
dumps/

# Never commit game assets (copyrighted)
*.pak
*.pcm
*.wav
*.wavadpcm

# Python / runtime
__pycache__/
*.pyc

# Recon runtime + downloaded binaries + generated combined script
tools/staging/
reference/
# generated: tools/dev/build.sh assembles it from tools/dev/src/
tools/dev/memexplore.js
tools/dev/*.tmp.js
tools/dev/memexplore.js.tmp
# generated by build.sh: embeds this machine's absolute Wine path
tools/dev/frida.config

# Runtime telemetry trace written by the Frida script (20-rpm.js); regenerate by driving
tools/dev/rpm.csv


# Runtime telemetry written by the harness each session (90-main.js) — churns constantly
tools/dev/dash.json
tools/dev/rpm.txt
tools/dev/explore.log
