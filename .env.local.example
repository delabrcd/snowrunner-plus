# Copy to .env.local (gitignored) and point it at your SnowRunner install.
# Everything in tools/ and mod/ resolves the game path through this — never hardcode it,
# so no machine-specific path is ever committed.
#
# The scripts autodetect the usual Steam library locations, so you only need this if your
# install lives somewhere unusual (second drive, custom library, flatpak Steam).

SR_GAME=/path/to/SteamLibrary/steamapps/common/SnowRunner

# Optional: where extracted game audio is staged during analysis (defaults to a temp dir).
#SR_SCRATCH=/path/to/scratch
